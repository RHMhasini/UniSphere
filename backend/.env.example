# =======================================================
# Environment Variables Template
# Copy this file to .env and fill in the actual values.
# NEVER commit the real .env file to version control!
# =======================================================

# ---- Database (MongoDB Atlas) ----
# Get connection string from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/SmartCampusDB?retryWrites=true&w=majority

# ---- Google OAuth2 ----
# Get credentials from: https://console.cloud.google.com
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ---- JWT ----
JWT_SECRET=your_super_secret_jwt_key_here_min_256_bits
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ---- Cloudinary (File/Image Uploads) ----
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
