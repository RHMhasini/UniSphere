# Root gitignore for UniSphere project

# Maven build output
/backend/target/

# IntelliJ / VS Code / editor files
/.idea/
/.vscode/
*.iml
*.ipr
*.iws
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Node.js dependencies and build outputs
/frontend/node_modules/
/frontend/dist/
/frontend/dist-ssr/

# OS files
*.swp
*.swo

# Environment files
.env
.env.*

# Package lock files if you prefer to ignore them
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
